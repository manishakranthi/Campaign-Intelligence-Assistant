# Groq API key (server-side only, used by src/app/api/chat/route.ts) -- primary LLM provider
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter API key -- fallback LLM provider, used automatically when Groq is rate-limited
# or unavailable. Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# NVIDIA NIM API key -- second fallback, tried when both Groq and OpenRouter are exhausted.
# Separate quota from OpenRouter's account-wide cap. Get a free key at https://build.nvidia.com
NVIDIA_API_KEY=

# --- Data source #1: Google Sheet (performance data) ---
# Set to "true" to use the real Google Sheets API instead of the mock data source.
USE_REAL_SHEETS=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# --- Data source #2: ticketing system (campaign metadata) ---
# Tool TBD (Jira/Zendesk/Freshdesk) -- mock implementation used until this is set.
USE_REAL_TICKETING=false

# --- Data source #3: trending audience signals ---
# google-trends-api needs no key. Meta Marketing API requires a connected
# Business Manager account with ads_read permission -- mocked until then.
META_AD_ACCOUNT_ID=
META_ACCESS_TOKEN=
